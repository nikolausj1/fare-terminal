# Path to the SQLite database file.
DATABASE_PATH=./data/fare-terminal.db

# Active flight data provider. "demo" is a stub until WP2; "travelpayouts"
# is the first real integration.
DATA_PROVIDER=demo

# Travelpayouts API token (required when DATA_PROVIDER=travelpayouts). Get
# one at https://www.travelpayouts.com -> Sign up -> API tab -> Data API
# token. If DATA_PROVIDER=travelpayouts but this is unset, the provider
# registry logs a warning and falls back to the demo provider.
TRAVELPAYOUTS_TOKEN=

# Travelpayouts affiliate marker, appended as ?marker=... to outbound
# aviasales.com booking links (buildOutboundUrl()). Optional, but required
# by Travelpayouts' program terms if you send booking traffic through this
# adapter — without it, buildOutboundUrl() returns null rather than an
# unmarked link. Obtained from the same Travelpayouts dashboard as the API
# token (Affiliate marker / "marker" field).
TRAVELPAYOUTS_MARKER=

# Client-side hourly request budget for the travelpayouts adapter. Kept
# below Travelpayouts' documented ~200 req/hour/IP limit so the adapter
# fails fast locally (ProviderError code RATE_LIMITED) instead of tripping
# the server-side limit. See docs/PROVIDERS.md for ingestion-cadence
# guidance.
TP_MAX_REQUESTS_PER_HOUR=100

# Anthropic API key, used for LLM-generated analyst notes. Optional —
# without it, analyst notes fall back to template generation.
ANTHROPIC_API_KEY=

# Set to "true" to force demo-mode data on the client.
NEXT_PUBLIC_DEMO_MODE=true
