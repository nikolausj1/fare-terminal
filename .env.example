# Fare Terminal environment variables. Copy this file to `.env` (or
# `.env.local`) and fill in what you need — every var below is optional
# with a documented default; the app runs fully on synthetic demo data with
# no .env file at all.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Path to the SQLite database file.
DATABASE_PATH=./data/fare-terminal.db

# Force the DB connection open read-only regardless of platform detection
# (db/index.ts#isDatabaseReadonly()). Useful for locally testing the
# read-only code paths that a Vercel runtime deployment takes. Normally
# unset — Vercel's own VERCEL=1 env var already triggers read-only mode at
# runtime without this.
DB_READONLY=

# Overrides both DB_READONLY and the automatic Vercel (VERCEL=1) read-only
# check, forcing a writable connection. Vercel's BUILD step also sets
# VERCEL=1, so scripts/build.mjs sets this internally while running
# db:setup/seed/pipeline to create the DB file the runtime later opens
# read-only. You shouldn't need to set this by hand outside that script.
DB_FORCE_WRITABLE=

# ---------------------------------------------------------------------------
# Data provider
# ---------------------------------------------------------------------------

# Active flight data provider: "demo" (default, fully synthetic) or
# "travelpayouts" (real cached/aggregated data). See docs/PROVIDERS.md.
DATA_PROVIDER=demo

# Travelpayouts API token (required when DATA_PROVIDER=travelpayouts). Get
# one at https://www.travelpayouts.com -> Sign up -> API tab -> Data API
# token. If DATA_PROVIDER=travelpayouts but this is unset, the provider
# registry logs a warning and falls back to the demo provider.
TRAVELPAYOUTS_TOKEN=

# Travelpayouts affiliate marker, appended as ?marker=... to outbound
# aviasales.com booking links (buildOutboundUrl()). Optional, but required
# by Travelpayouts' program terms if you send booking traffic through this
# adapter — without it, buildOutboundUrl() returns null rather than an
# unmarked link. Obtained from the same Travelpayouts dashboard as the API
# token (Affiliate marker / "marker" field).
TRAVELPAYOUTS_MARKER=

# Client-side hourly request budget for the travelpayouts adapter. Kept
# below Travelpayouts' documented ~200 req/hour/IP limit so the adapter
# fails fast locally (ProviderError code RATE_LIMITED) instead of tripping
# the server-side limit. See docs/PROVIDERS.md for ingestion-cadence
# guidance. Default (unset) is 100.
TP_MAX_REQUESTS_PER_HOUR=100

# ---------------------------------------------------------------------------
# Demo data / seeding
# ---------------------------------------------------------------------------

# Pins the demo dataset's notion of "now" (ISO-8601, or anything
# Date.parse() accepts) so scenario event windows ("last 48h", "last 72h",
# ...) stay stable across a seed + pipeline run. Only affects `npm run
# seed`/`npm run pipeline` (lib/demo-time.ts#getNow()) — the UI itself
# always computes freshness relative to the dataset's own newest
# observation (lib/markets/queries.ts#getDatasetAnchor()), never the real
# wall clock, so an unset DEMO_NOW never makes the demo look artificially
# stale. Unset = real Date.now() at seed time.
DEMO_NOW=

# Set to "1" to force scripts/build.mjs to re-run db:setup + seed +
# pipeline on every build, even when data/fare-terminal.db already exists —
# e.g. to refresh the demo dataset's anchor time on a redeploy. Normally
# unset (the build only seeds when the DB file is missing).
SEED_ON_BUILD=

# ---------------------------------------------------------------------------
# Analyst notes (LLM)
# ---------------------------------------------------------------------------

# Anthropic API key, used for LLM-generated analyst notes when ANALYST_LLM=1.
# Optional — without it (or without ANALYST_LLM=1), analyst notes always
# fall back to template generation, which is deterministic and never fails.
ANTHROPIC_API_KEY=

# Gates whether jobs/analyst-notes.ts attempts an LLM call at all — both
# this AND ANTHROPIC_API_KEY must be set. Kept as a separate flag (rather
# than just checking for the key) so CI/tests/local dev never accidentally
# make a live LLM call just because a key happens to be in the environment.
ANALYST_LLM=

# ---------------------------------------------------------------------------
# Site metadata / deployment
# ---------------------------------------------------------------------------

# Canonical site URL used for metadata.metadataBase (app/layout.tsx) —
# affects absolute URLs in Open Graph/canonical tags. Falls back to
# `https://${VERCEL_URL}` (set automatically by Vercel) and then to
# http://localhost:3111 if unset.
NEXT_PUBLIC_SITE_URL=

# Port `next start` binds to in production (Next.js reads this itself; no
# app code references it directly). Local dev instead passes --port
# explicitly (see the `dev`/`test:e2e` scripts, which use 3111). Vercel
# ignores this and manages the port itself.
PORT=

# Reserved for a client-side demo-mode override; not currently read by any
# code path (server components check DATA_PROVIDER directly instead — see
# components/ui/DemoBanner.tsx, lib/markets/queries.ts#isDemoMode()). Left
# here as a documented placeholder rather than silently dropped.
NEXT_PUBLIC_DEMO_MODE=true
